# ===== W&B (Serverless RL / ログ記録) =====
# https://wandb.ai/authorize で取得
WANDB_API_KEY=your-wandb-api-key

# 学習結果を記録する W&B の Team entity 名とプロジェクト名
# Serverless RL では個人ユーザー名ではなく、W&B Training が有効な Team entity を指定してください。
WANDB_ENTITY=your-team-entity
WANDB_PROJECT=art-e-nano

# ===== OpenAI (任意: LLM judge / プロンプトベースラインの評価) =====
# https://platform.openai.com/api-keys で取得
# OpenAI API key がない場合は、この行はコメントのまま JUDGE_MODE=heuristic を使ってください。
# OPENAI_API_KEY=your-openai-api-key

# ===== オプション =====
# 回答の正誤判定に使うジャッジモデル (デフォルト: gpt-5.5)
# JUDGE_MODEL=gpt-5.5

# ジャッジの推論量。通常は low で十分
# JUDGE_REASONING_EFFORT=low

# auto: LLM を試し、障害時または OPENAI_API_KEY 未設定時は heuristic に切替 (デフォルト)
# OpenAI API key がない場合は次の行を有効化してください。
# JUDGE_MODE=heuristic

# RULER を使う場合は、主報酬を置き換えず補助加点として混ぜる
# USE_RULER=false
# RULER_WEIGHT=0.2

# "I don't know" への退避を抑えるペナルティ
# IDK_PENALTY=0.2

# 学習するモデルの名前 (毎回ユニーク推奨)
# MODEL_NAME=art-e-nano-workshop
