# ===== W&B (Serverless RL / ログ記録) =====
# https://wandb.ai/authorize で取得
WANDB_API_KEY=your-wandb-api-key

# 学習結果を記録する W&B の entity (チーム名 or ユーザー名) とプロジェクト名
WANDB_ENTITY=your-entity
WANDB_PROJECT=art-e-nano

# ===== OpenAI (ジャッジモデル / プロンプトベースラインの評価) =====
# https://platform.openai.com/api-keys で取得
OPENAI_API_KEY=your-openai-api-key

# ===== オプション =====
# 回答の正誤判定に使うジャッジモデル (デフォルト: gpt-5.5)
# JUDGE_MODEL=gpt-5.5

# auto: LLM を試し、障害時のみ heuristic に切替 (デフォルト)
# JUDGE_MODE=auto

# 学習するモデルの名前 (毎回ユニーク推奨)
# MODEL_NAME=art-e-nano-workshop
